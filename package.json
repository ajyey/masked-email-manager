{
  "name": "masked-email-manager",
  "displayName": "Masked Email Manager",
  "description": "A web extension to manage your Fastmail masked emails",
  "version": "1.7.5",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ajyey/masked-email-manager.git"
  },
  "packageManager": "yarn@4.17.1",
  "engines": {
    "node": "24.x"
  },
  "type": "module",
  "scripts": {
    "build": "run-s build:production:chrome build:production:firefox verify:build",
    "build:production:chrome": "vite build",
    "build:production:firefox": "BROWSER=firefox vite build",
    "check": "run-s lint typecheck test build",
    "lint": "run-s lint:ts lint:format",
    "lint:ts": "eslint src utils tests vite.config.ts playwright.config.ts eslint.config.js --ext .ts,.tsx",
    "lint:format": "prettier --config .prettierrc 'src/**/*.{ts,tsx,html}' 'utils/**/*.{js,ts,tsx}' 'tests/**/*.{ts,tsx}' vite.config.ts playwright.config.ts eslint.config.js --check",
    "lint:fix": "run-s lint:fix:ts lint:fix:format",
    "lint:fix:ts": "eslint src utils tests vite.config.ts playwright.config.ts eslint.config.js --ext .ts,.tsx --fix",
    "lint:fix:format": "prettier --config .prettierrc 'src/**/*.{ts,tsx,html}' 'utils/**/*.{js,ts,tsx}' 'tests/**/*.{ts,tsx}' vite.config.ts playwright.config.ts eslint.config.js --write",
    "test": "vitest run",
    "test:e2e": "run-s build:production:chrome test:e2e:run",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:run": "playwright test",
    "test:e2e:headed": "E2E_HEADED=1 playwright test",
    "test:e2e:debug": "E2E_HEADED=1 PWDEBUG=1 playwright test",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "dev": "run-p dev:chrome dev:firefox",
    "dev:chrome": "__DEV__=true vite build --watch",
    "dev:firefox": "__DEV__=true BROWSER=firefox vite build --watch",
    "verify:build": "node utils/verify-build.js",
    "semantic-release": "semantic-release",
    "upgrade-packages": "npx npm-check-updates -u && yarn",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "fastmail-masked-email": "3.0.3",
    "fuse.js": "^7.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hot-toast": "^2.5.2",
    "vite-plugin-css-injected-by-js": "^3.5.2",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.61.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.1",
    "@semantic-release/npm": "^12.0.1",
    "@semantic-release/release-notes-generator": "^14.0.3",
    "@tailwindcss/postcss": "^4.1.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/chrome": "^0.0.313",
    "@types/node": "^22.14.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.1",
    "@types/webextension-polyfill": "^0.12.3",
    "@vitejs/plugin-react-swc": "^3.8.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fs-extra": "^11.3.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "npm-run-all": "^4.1.5",
    "patch-package": "^8.0.0",
    "postcss": "^8.5.3",
    "postinstall-postinstall": "^2.1.0",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "run-script-os": "^1.1.6",
    "semantic-release": "^24.2.3",
    "semantic-release-chrome": "^3.2.0",
    "semantic-release-firefox-add-on": "^0.2.8",
    "tailwindcss": "^4.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.64.0",
    "vite": "^6.2.4",
    "vitest": "^4.1.10"
  }
}
